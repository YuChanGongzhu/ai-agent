# Airflow 配置
REACT_APP_AIRFLOW_BASE_URL='http://<AIRFLOW_BASE_URL>/api/v1' # Airflow API 基础 URL
REACT_APP_AIRFLOW_USERNAME='<AIRFLOW_USERNAME>' # Airflow 用户名
REACT_APP_AIRFLOW_PASSWORD='<AIRFLOW_PASSWORD>' # Airflow 密码

# Dify 配置
REACT_APP_DIFY_BASE_URL='http://<DIFY_BASE_URL>/v1' # Dify API 基础 URL
REACT_APP_DIFY_API_KEY1='<DIFY_API_KEY1>' # Dify API 密钥1
REACT_APP_DIFY_API_KEY2='<DIFY_API_KEY2>' # Dify API 密钥2
REACT_APP_DIFY_API_KEY3='<DIFY_API_KEY3>' # Dify API 密钥3
REACT_APP_DIFY_DATASET_API_KEY='<DIFY_DATASET_API_KEY>' # Dify 数据集 API 密钥
REACT_APP_DIFY_CHATBOT_ID='http://<DIFY_CHATBOT_URL>/chatbot/<CHATBOT_ID>' # Dify 聊天机器人 ID

# 腾讯云函数配置
REACT_APP_GET_ROOM_MSG_LIST='https://<TENCENT_CLOUD_FUNCTION_URL>' # 获取房间消息列表的 URL
REACT_APP_GET_ROOM_LIST='https://<TENCENT_CLOUD_FUNCTION_URL>' # 获取房间列表的 URL

# Grafana 配置
REACT_APP_GRAFANA_URL='http://<GRAFANA_URL>:3000/goto/<GRAFANA_DASHBOARD_ID>?orgId=1' # Grafana URL

# Windows 服务器配置
REACT_APP_WINDOWS_SERVER_IPS=<WINDOWS_SERVER_IPS> # Windows 服务器 IP 列表
REACT_APP_WINDOWS_SERVER_NAMES=<WINDOWS_SERVER_NAMES> # Windows 服务器名称列表

# Guacamole 配置
REACT_APP_GUACAMOLE_ADMIN_USERNAME='<GUACAMOLE_ADMIN_USERNAME>' # Guacamole 管理员用户名
REACT_APP_GUACAMOLE_ADMIN_PASSWORD='<GUACAMOLE_ADMIN_PASSWORD>' # Guacamole 管理员密码
REACT_APP_GUACAMOLE_URL='http://<GUACAMOLE_URL>:8088' # Guacamole URL

# Nacos 配置
REACT_APP_NACOS_SERVER='http://<NACOS_SERVER>:8848' # Nacos 服务器地址
REACT_APP_NACOS_USERNAME='nacos' # Nacos 用户名
REACT_APP_NACOS_PASSWORD='nacos' # Nacos 密码
REACT_APP_NACOS_NAMESPACE='public' # Nacos 命名空间

# Nacos 认证配置（如果启用了认证）
REACT_APP_NACOS_AUTH_ENABLE='true' # 是否启用认证（true/false）
REACT_APP_NACOS_AUTH_IDENTITY_KEY='serverIdentity' # 认证身份键名
REACT_APP_NACOS_AUTH_IDENTITY_VALUE='security' # 认证身份值
REACT_APP_NACOS_AUTH_TOKEN='SecretKey012345678901234567890123456789012345678901234567890123456789' # 认证令牌
